# ---------------------------------------------------------------------------
# Copy this file to `.env` and fill in the values. NEVER commit `.env`.
# Provider: Mistral La Plateforme (EU). Free "Experiment" tier covers the whole
# workshop — create a key at https://console.mistral.ai (phone verification, no
# credit card). GDPR: La Plateforme API data is NOT used for training.
# ---------------------------------------------------------------------------

# --- Mistral La Plateforme -------------------------------------------------
MISTRAL_API_KEY="..."
MISTRAL_CHAT_MODEL="mistral-large-latest"     # main model (free tier OK)
MISTRAL_SMALL_MODEL="mistral-small-latest"   # cheap model for graders/judges
MISTRAL_EMBED_MODEL="mistral-embed"          # embeddings (1024 dims)

# --- Observability: LangSmith (EU endpoint for GDPR) -----------------------
LANGSMITH_TRACING="true"
LANGSMITH_ENDPOINT="https://eu.api.smith.langchain.com"
LANGSMITH_API_KEY="lsv2_..."
LANGSMITH_PROJECT="agentic-ai-labs"

# --- Lab knobs (safe defaults; see src/shared/env.ts) ----------------------
MAX_OUTPUT_TOKENS="800"        # hard cap on model output (cost guard)
RECURSION_LIMIT="8"           # LangGraph anti-loop guard
RETRIEVER_TOP_K="4"          # chunks pulled per retrieval
